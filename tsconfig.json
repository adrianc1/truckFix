{
	"compilerOptions": {
		"target": "ES2023",
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",

		"esModuleInterop": true,
		"ignoreDeprecations": "6.0",

		"strict": true,
		"noEmit": true,
		"isolatedModules": true,
		"skipLibCheck": true,

		"resolveJsonModule": true,
		"allowImportingTsExtensions": true,
		"types": ["vite/client"]
	},
	"include": ["src"]
}
