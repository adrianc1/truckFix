generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id                   String        @id @default(uuid())
  source               String        @default("manual")
  name                 String
  formattedAddress     String
  lat                  Float
  lng                  Float
  phone                String?
  website              String?
  businessStatus       String?
  priceLevel           Int?
  rating               Float?
  userRatingsTotal     Int?
  specializesInTrucks  Boolean       @default(false)
  acceptsLargeVehicles Boolean       @default(false)
  status               String        @default("pending")
  lastSyncedAt         DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  placeId              String?       @unique @map("place_id")
  acceptsFleet         Boolean       @default(false)
  hasDriverLounge      Boolean       @default(false)
  hasTruckParking      Boolean       @default(false)
  is24Hours            Boolean       @default(false)
  isMobileService      Boolean       @default(false)
  vicinity             String?
  isClaimed            Boolean       @default(false)
  isFeatured           Boolean       @default(false)
  hours                ShopHours[]
  photos               ShopPhoto[]
  reviews              ShopReview[]
  services             ShopService[]

  @@index([lat, lng])
}

model ShopHours {
  id        String  @id @default(uuid())
  shopId    String
  dayOfWeek Int
  openTime  String?
  closeTime String?
  isClosed  Boolean @default(false)
  shop      Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, dayOfWeek])
}

model ShopService {
  id      String @id @default(uuid())
  shopId  String
  service String
  shop    Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model ShopPhoto {
  id             String @id @default(uuid())
  shopId         String
  photoReference String
  width          Int?
  height         Int?
  source         String @default("google")
  shop           Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model ShopReview {
  id          String    @id @default(uuid())
  shopId      String
  source      String
  authorName  String?
  authorPhoto String?
  rating      Int
  text        String?
  publishedAt DateTime?
  userId      String?
  createdAt   DateTime  @default(now())
  shop        Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
}
