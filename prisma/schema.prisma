generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id               String   @id @default(uuid())
  placeId          String?  @unique @map("place_id")
  source           String   @default("manual") // "google" | "manual"

  // Core info
  name             String
  formattedAddress String
  vicinity         String?
  lat              Float
  lng              Float
  phone            String?
  website          String?
  businessStatus   String?  // "OPERATIONAL", "CLOSED_TEMPORARILY", etc.
  priceLevel       Int?

  // Ratings
  rating           Float?
  userRatingsTotal Int?

  // Truck-specific flags 
  specializesInTrucks   Boolean @default(false)
  acceptsLargeVehicles  Boolean @default(false)
  isMobileService       Boolean @default(false)
  is24Hours             Boolean @default(false)
  hasDriverLounge       Boolean @default(false)
  hasTruckParking       Boolean @default(false)
  acceptsFleet          Boolean @default(false)

  // Verification
  status           String   @default("pending") // "pending" | "verified" | "rejected"
  isFeatured       Boolean  @default(false)
  isClaimed        Boolean  @default(false)

  // Cache control
  lastSyncedAt     DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([lat, lng])

  // Relations
  hours            ShopHours[]
  services         ShopService[]
  photos           ShopPhoto[]
  reviews          ShopReview[]
}

model ShopHours {
  id          String  @id @default(uuid())
  shopId      String
  shop        Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  dayOfWeek   Int     // 0 = Sunday, 6 = Saturday
  openTime    String? // "08:00"
  closeTime   String? // "18:00"
  isClosed    Boolean @default(false)

  @@unique([shopId, dayOfWeek])
}

model ShopService {
  id      String @id @default(uuid())
  shopId  String
  shop    Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  service String // "brakes" | "tires" | "diesel" | "engine" | etc.
}

model ShopPhoto {
  id             String @id @default(uuid())
  shopId         String
  shop           Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  photoReference String
  width          Int?
  height         Int?
  source         String @default("google") // "google" | "manual"
}

model ShopReview {
  id          String   @id @default(uuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  source      String   // "google" | "platform"

  // Google reviews
  authorName  String?
  authorPhoto String?
  rating      Int      // 1-5
  text        String?
  publishedAt DateTime?

  // Platform reviews (source = "platform")
  userId      String?  // future User relation

  createdAt   DateTime @default(now())
}